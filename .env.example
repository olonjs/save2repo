# save2repo — example environment variables
# Copy to .env.local for local development; in production these are injected
# automatically by the Vercel Marketplace install flow (see ADR-007).

# --- Supabase (the buyer's own project, not ours) ---
# Auto-populated by the Supabase Vercel Marketplace integration on install.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- save2repo deployment registration ---
# Issued by the olonjs Marketplace install callback and injected into this
# Vercel project's env automatically. Required at runtime to call the olonjs
# GitHub token-signing endpoint (see ADR-006).
SAVE2REPO_DEPLOYMENT_TOKEN=

# --- olonjs backend (default is fine in production) ---
OLONJS_API_BASE=https://app.olon.it/api/v1

# --- Public URL of this deployment ---
# Vercel sets VERCEL_URL automatically; this is the canonical/branded URL.
# NEXT_PUBLIC_APP_URL=https://your-save2repo.vercel.app
